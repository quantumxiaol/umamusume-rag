## LLM Settings
## support openai and dashscope(qwen)
INFO_LLM_MODEL_NAME=qwen-max-latest
INFO_LLM_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
INFO_LLM_MODEL_API_KEY=

# INFO_LLM_MODEL_NAME=
# INFO_LLM_MODEL_BASE_URL=https://api.openai.com/v1
# INFO_LLM_MODEL_API_KEY=gpt-4o

## DASHSCOPE_API_KEY is use for qwen embedding API,but for now we use local embedding model
DASHSCOPE_API_KEY=

## RAG Settings

HF_Embedding_Model=Qwen/Qwen3-Embedding-0.6B
# Qwen/Qwen3-Embedding-0.6B
# BAAI/bge-large-zh-v1.5
EMBEDDING_DEVICE=mps

RAG_DIRECTORY=./resources/docs
CHUNK_SIZE=500
CHUNK_OVERLAP=100

### Mineru setting
HAS_MINERU=True
# 模型缓存目录 - 所有 HuggingFace 模型会下载到这里
HF_HOME=./models
HUGGINGFACE_HUB_CACHE=./models/hub

# HuggingFace 镜像源（国内用户可选）
# HF_ENDPOINT=https://hf-mirror.com

# MinerU 设备配置
# 可选: cpu, cuda, cuda:0, mps (macOS Apple Silicon)
MINERU_DEVICE=cuda

### PDF processor setting
PDF_PROCESSOR_ENGINE=mineru

### Qwen2.5-VL OCR
QWEN_VL_MODEL_DIR=./models/Qwen2.5-VL-7B-Instruct
QWEN_VL_REPO_ID=Qwen/Qwen2.5-VL-7B-Instruct
QWEN_VL_DEVICE=auto
QWEN_VL_DTYPE=auto
QWEN_VL_MAX_TOKENS=2048
