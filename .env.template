# Core RAG settings.
RAG_DIRECTORY=./resources/docs
HF_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_DEVICE=cpu
CHUNK_SIZE=2000
CHUNK_OVERLAP=200

# Keep model/cache files inside the project by default.
HF_HOME=./models
HUGGINGFACE_HUB_CACHE=./models/hub

# Optional: HuggingFace mirror.
# HF_ENDPOINT=https://hf-mirror.com

# Optional LLM settings. Required only for /ask and MCP rag answers.
# Install with: uv sync --extra llm
INFO_LLM_MODEL_NAME=qwen-max-latest
INFO_LLM_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
INFO_LLM_MODEL_API_KEY=

# Optional PDF conversion. Keep disabled for a pure Markdown/TXT/CSV knowledge base.
# Install engines with: uv sync --extra pdf-markitdown / pdf-mineru / pdf-docling / pdf-qwen-vl
PDF_PROCESSOR_ENGINE=none
AUTO_CONVERT_PDF_TO_MD=false
PREFER_MARKDOWN_FILES=true

# Optional engine-specific settings.
# MINERU_MODEL_DIR=./models/hub
# MINERU_DEVICE_MODE=cpu
# QWEN_VL_MODEL_DIR=./models/Qwen2.5-VL-7B-Instruct
# QWEN_VL_DEVICE=auto
# QWEN_VL_DTYPE=auto
# QWEN_VL_MAX_TOKENS=2048
